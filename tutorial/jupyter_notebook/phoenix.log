CREATE TABLE experiment_jobs (
	id INTEGER NOT NULL, 
	type VARCHAR NOT NULL CONSTRAINT "ck_experiment_jobs_`valid_type`" CHECK (type IN ('PROMPT', 'EVAL_ONLY')), 
